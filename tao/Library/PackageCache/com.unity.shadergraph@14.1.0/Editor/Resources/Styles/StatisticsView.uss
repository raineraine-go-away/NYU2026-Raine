StatisticsView {
    position: absolute;
    bottom: 3px;
    left: 3px;
    width: 500px;
    height: 50px;
    background-color:rgba(37, 37, 37, 0);
}

StatisticsView > #statsInfo {
    position: absolute;
    bottom: 0px;
    left: 0px;
    overflow: hidden;
    font-size: 12px;
    color: rgb(180, 180, 180);
    -unity-text-align: lower-left;
}